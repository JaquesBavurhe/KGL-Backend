# App Environment
NODE_ENV=development
PORT=3000

# Database
# Encode special characters in username/password (e.g. @ as %40)
MONGODB_URI=mongodb+srv://<db_user>:<db_password>@<cluster-host>/<database>?retryWrites=true&w=majority

# Auth
# Use a long random secret in real environments
JWT_SECRET=replace_with_a_long_random_secret
# Examples: 15m, 1h, 24h, 7d
JWT_EXPIRES_IN=1h

# CORS + Cookies (for Netlify frontend -> Render backend deployment)
# Comma-separated origins allowed to call this API
CORS_ALLOWED_ORIGINS=https://your-app.netlify.app,http://localhost:3000
# Set to true when frontend and backend are on different origins
CROSS_SITE_COOKIES=false
